# Copie este arquivo para .env.local e defina um valor forte para a variável abaixo.
# O .env.local é ignorado pelo git (.gitignore cobre .env*).
#
# No EasyPanel, configure esta variável em Environment Variables do serviço,
# não crie o arquivo .env.local diretamente no servidor.
#
# ATENÇÃO: Esta variável é prefixada com NEXT_PUBLIC_, portanto seu valor
# ficará embutido no bundle JavaScript após o build. A proteção primária
# real deve ser o auth_basic do Nginx configurado em nginx.conf.
# Use uma senha forte e diferente da senha do Nginx.

NEXT_PUBLIC_ADMIN_KEY=troque-por-uma-senha-forte-aqui
